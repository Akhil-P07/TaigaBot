# ── TaigaBot configuration ──────────────────────────────────────────────
# Copy this file to ".env" and fill in the values. Never commit your real .env.
# On Replit, put these in the Secrets tab instead (changes need a restart).

# ── Discord ───────────────────────────────────────────────────────────────
# Bot token: Developer Portal -> your app -> Bot -> Reset Token.
DISCORD_TOKEN=your-bot-token-here

# OPTIONAL dev/test server ID. Commands ALWAYS sync globally (works in every
# server the bot joins; can take ~1h to appear the first time). Setting GUILD_ID
# also syncs instantly to that one server — handy while developing. Blank in prod.
GUILD_ID=

# ── Email (OTP verification) ──────────────────────────────────────────────
# OTP codes are sent via Brevo's HTTP API (port 443) — SMTP is blocked on hosts
# like Railway/Render. Setup (free): https://app.brevo.com
#   1) Senders & IPs -> add + verify your sender email (click the link; NO domain
#      needed). 2) SMTP & API -> API Keys -> create a key.
BREVO_API_KEY=your-brevo-api-key
# The "From" address — must be the Brevo-verified sender above.
EMAIL_FROM=yourclubbot@gmail.com
EMAIL_FROM_NAME=TaigaBot

# Allowed university email domains (comma-separated, no @). Both RIT domains are
# treated as the same person (verification is keyed on the part before the @).
ALLOWED_EMAIL_DOMAINS=rit.edu,g.rit.edu

# OTP behaviour.
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ── Role / channel names ──────────────────────────────────────────────────
# Resolved by name; /setup creates them if missing.
EBOARD_ROLE_NAME=Eboard
UNVERIFIED_ROLE_NAME=Unverified
VERIFIED_ROLE_NAME=Verified
UNVERIFIED_CHANNEL_NAME=unverified
WELCOME_CHANNEL_NAME=welcome
MODLOG_CHANNEL_NAME=mod-log
BACKUP_CHANNEL_NAME=taiga-backups
ROLES_CHANNEL_NAME=roles

# ── /setup behaviour (both are also prompted interactively when you run /setup;
#    these env values just act as the defaults) ──────────────────────────────
# Channel/category IDs /setup leaves untouched (no @everyone-deny/Verified-allow).
# A CATEGORY id skips every channel inside it — e.g. a Projects category you gate
# behind project roles. Copy IDs via right-click (Developer Mode on).
GATING_IGNORE=

# DESTRUCTIVE: when 1, /setup first REMOVES every member's roles (except Eboard/
# Verified/Unverified, bot-managed roles, and roles above TaigaBot) so old roles
# stop granting access until members re-verify and re-pick in #roles. Runs on
# EVERY /setup — enable, run once, set back to 0.
RESET_ROLES_ON_SETUP=0

# ── Storage & backups ──────────────────────────────────────────────────────
# SQLite path. On Replit, point this at a stable path so redeploys don't wipe it.
DB_PATH=taigabot.db

# How often the bot uploads an automatic per-server backup to #taiga-backups.
BACKUP_INTERVAL_HOURS=12
# Optional: override the backup destination with a specific channel ID instead of
# the auto-created #taiga-backups. ⚠️ Keep it PRIVATE/Eboard-only (names+emails).
BACKUP_CHANNEL_ID=

# ── Gemini AI assistant (/ask) ─────────────────────────────────────────────
# Free API key from https://aistudio.google.com/apikey . Blank disables /ask.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
