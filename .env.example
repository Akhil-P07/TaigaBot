# ── TaigaBot configuration ──────────────────────────────────────────────
# Copy this file to ".env" and fill in the values. Never commit your real .env

# Discord bot token (Discord Developer Portal -> your app -> Bot -> Reset Token)
DISCORD_TOKEN=your-bot-token-here

# OPTIONAL dev/test server (guild) ID. Right-click the server icon -> Copy
# Server ID (enable Developer Mode in Discord settings first). Commands are
# ALWAYS synced globally so the bot works in every server it's invited to (this
# can take up to ~1 hour to appear the first time). If you set GUILD_ID, that one
# server also gets instant command updates — handy while developing. Leave blank
# in production.
GUILD_ID=

# ── Email (OTP verification) ────────────────────────────────────────────
# A Gmail account the bot sends the 6-digit verification code from.
# You MUST use a Google "App Password", NOT your normal password:
#   https://myaccount.google.com/apppasswords  (requires 2FA enabled)
GMAIL_ADDRESS=yourclubbot@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# ── Role / channel names ────────────────────────────────────────────────
# The bot looks these roles/channels up by name and creates them via /setup.
EBOARD_ROLE_NAME=Eboard
UNVERIFIED_ROLE_NAME=Unverified
VERIFIED_ROLE_NAME=Verified
UNVERIFIED_CHANNEL_NAME=unverified
WELCOME_CHANNEL_NAME=welcome
MODLOG_CHANNEL_NAME=mod-log
BACKUP_CHANNEL_NAME=taiga-backups
ROLES_CHANNEL_NAME=roles

# ── Channels /setup should NOT gate ──────────────────────────────────────
# Comma-separated channel/category IDs that /setup leaves untouched. Put a
# CATEGORY id to skip every channel in it — e.g. a Projects/Interests category
# you gate behind interest roles yourself (deny @everyone + Verified view, allow
# each interest role). Right-click -> Copy Channel/Category ID (Developer Mode).
GATING_IGNORE=

# ── Fresh-start role reset (DESTRUCTIVE — leave 0 unless you mean it) ──────
# When 1, /setup first REMOVES every member's roles (except Eboard/Verified/
# Unverified, bot-managed roles, and roles above TaigaBot) so old interest/
# self-assign roles stop granting access until members re-verify and re-pick in
# #roles. Runs on EVERY /setup — enable, run /setup once, then set back to 0.
RESET_ROLES_ON_SETUP=0

# Allowed university email domains (comma-separated, no @)
ALLOWED_EMAIL_DOMAINS=rit.edu,g.rit.edu

# OTP settings
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ── Database backups ────────────────────────────────────────────────────
# /setup auto-creates the Eboard-only #taiga-backups channel (see
# BACKUP_CHANNEL_NAME above) and the bot uploads a snapshot there on a schedule,
# so data survives even if the host wipes its filesystem (e.g. a Replit rebuild).
# Each server's backup contains ONLY that server's data.
# How often to upload an automatic backup.
BACKUP_INTERVAL_HOURS=12
# Optional: override the destination with a specific channel ID instead of the
# auto-created #taiga-backups. ⚠️ Must stay PRIVATE/Eboard-only (real names +
# emails). Right-click the channel -> Copy Channel ID (Developer Mode on).
BACKUP_CHANNEL_ID=
